#!/usr/bin/env bash
# fleet — manage a durable fleet of claude (or any) terminal sessions.
#
# One dedicated tmux server on a private socket (~/.tmux/fleet.sock) that lives
# OUTSIDE /tmp, so systemd's 30-day /tmp sweep can't orphan it, and outside your
# ssh ptys, so disconnects don't SIGHUP your agents. One window per session.
#
# The point: ssh in once, `fleet attach`, every session is there. Walk away,
# come back days later, still running. An AI manager rides on `fleet status --json`.
#
#   fleet new <name> [cmd...]   spawn a window (default cmd: claude). e.g. fleet new yt
#   fleet ls                    list sessions + live state (idle/working/waiting)
#   fleet status [--json]       machine-readable state of every session (for the AI manager)
#   fleet peek <name> [lines]   show what that session is currently doing (default 40 lines)
#   fleet send <name> <text>    type <text> into a session and hit enter (dispatch work)
#   fleet attach [name]         attach to the fleet (optionally jump to one window)
#   fleet kill <name>           close a session
#   fleet adopt <name> [cmd]    alias for `new` — start a project session by convention
#   fleet manager               launch the AI manager (a subscription-billed claude that watches the fleet)
#   fleet detect                inventory ALL claudes on the box: which are in-fleet vs orphan raw-pty
#   fleet adopt-live <pid> [nm] pull a RUNNING claude (raw ssh pty) into the fleet via reptyr (experimental)
#   fleet up                    ensure the fleet server is running (idempotent)
#
set -euo pipefail

SOCK="$HOME/.tmux/fleet.sock"
CONF="$HOME/.tmux/fleet.conf"
T() { tmux -S "$SOCK" -f "$CONF" "$@"; }

ensure_server() {
  if ! tmux -S "$SOCK" has-session 2>/dev/null; then
    # start detached with a hidden keepalive window so the server never has 0 windows
    T new-session -d -s _fleet -n _keepalive "exec sleep infinity"
    T set -t _fleet status on >/dev/null 2>&1 || true
  fi
}

# classify a window's state by scraping its pane (works for the claude TUI)
state_of() {
  local target="$1" cap
  cap="$(T capture-pane -p -t "$target" 2>/dev/null | tail -50 || true)"
  if grep -qiE "esc to interrupt|✶|✳|✻|Working…|Thinking…|Forging…|tokens · esc" <<<"$cap"; then
    echo working
  elif grep -qiE "Do you want|❯ 1\.|Proceed\?|\(y/n\)|press enter to continue" <<<"$cap"; then
    echo waiting
  elif grep -qE "│ >|╰─|\? for shortcuts|>_" <<<"$cap"; then
    echo idle
  elif [[ -z "${cap// /}" ]]; then
    echo blank
  else
    echo active
  fi
}

# windows in the _fleet session, excluding the keepalive
win_list() {
  T list-windows -t _fleet -F "#{window_index}	#{window_name}	#{pane_pid}	#{window_activity}" 2>/dev/null \
    | grep -vP "\t_keepalive\t" || true
}

cmd="${1:-ls}"; shift || true

case "$cmd" in
  up)
    ensure_server
    echo "fleet server up on $SOCK"
    ;;

  new|adopt)
    ensure_server
    name="${1:?usage: fleet new <name> [cmd...]}"; shift || true
    run="${*:-claude --dangerously-skip-permissions}"
    if T list-windows -t _fleet -F "#{window_name}" 2>/dev/null | grep -qx "$name"; then
      echo "session '$name' already exists — fleet attach $name"; exit 1
    fi
    T new-window -t _fleet -n "$name" "$run"
    echo "started '$name' running: $run"
    echo "  watch it:  fleet attach $name    (detach: ctrl-b then d)"
    ;;

  ls)
    ensure_server
    printf "%-18s %-9s %s\n" SESSION STATE "LAST ACTIVITY"
    printf "%-18s %-9s %s\n" "-------" "-----" "-------------"
    while IFS=$'\t' read -r idx nm pid act; do
      [[ -z "${nm:-}" ]] && continue
      st="$(state_of "_fleet:$idx")"
      when="$(date -d "@$act" "+%b %d %H:%M" 2>/dev/null || echo "?")"
      printf "%-18s %-9s %s\n" "$nm" "$st" "$when"
    done < <(win_list)
    ;;

  status)
    ensure_server
    if [[ "${1:-}" == "--json" ]]; then
      printf '['
      first=1
      while IFS=$'\t' read -r idx nm pid act; do
        [[ -z "${nm:-}" ]] && continue
        st="$(state_of "_fleet:$idx")"
        last="$(T capture-pane -p -t "_fleet:$idx" 2>/dev/null | grep -vE '^\s*$' | tail -1 | tr -d '\r' | sed 's/"/\\"/g' | cut -c1-160 || true)"
        [[ $first -eq 0 ]] && printf ','
        printf '{"name":"%s","state":"%s","activity":%s,"last_line":"%s"}' "$nm" "$st" "$act" "$last"
        first=0
      done < <(win_list)
      printf ']\n'
    else
      exec "$0" ls
    fi
    ;;

  peek)
    ensure_server
    name="${1:?usage: fleet peek <name> [lines]}"; lines="${2:-40}"
    T capture-pane -p -t "_fleet:$name" 2>/dev/null | tail -"$lines" \
      || { echo "no session '$name'"; exit 1; }
    ;;

  send)
    ensure_server
    name="${1:?usage: fleet send <name> <text>}"; shift
    text="$*"
    T send-keys -t "_fleet:$name" "$text" 2>/dev/null || { echo "no session '$name'"; exit 1; }
    T send-keys -t "_fleet:$name" Enter
    echo "→ sent to '$name': $text"
    ;;

  attach)
    ensure_server
    if [[ -n "${1:-}" ]]; then
      T select-window -t "_fleet:$1" 2>/dev/null || { echo "no session '$1'"; exit 1; }
    fi
    if [[ -n "${TMUX:-}" ]]; then T switch-client; else T attach -t _fleet; fi
    ;;

  detect)
    ensure_server
    # ttys currently owned by fleet panes → anything else is an orphan raw-pty claude
    mapfile -t fleet_ttys < <(T list-panes -s -t _fleet -F "#{pane_tty}" 2>/dev/null | sed 's#^/dev/##')
    in_fleet() { local t="$1"; for f in "${fleet_ttys[@]:-}"; do [[ "$f" == "$t" ]] && return 0; done; return 1; }
    printf "%-8s %-9s %-9s %-10s %s\n" PID TTY WHERE AGE CWD
    printf "%-8s %-9s %-9s %-10s %s\n" "---" "---" "-----" "---" "---"
    found=0
    while read -r pid tty etime; do
      [[ -z "${pid:-}" ]] && continue
      found=1
      cwd="$(readlink "/proc/$pid/cwd" 2>/dev/null || echo '?')"
      cwd="${cwd/#$HOME/\~}"
      if in_fleet "$tty"; then where="in-fleet"; else where="ORPHAN"; fi
      printf "%-8s %-9s %-9s %-10s %s\n" "$pid" "$tty" "$where" "$etime" "$cwd"
    done < <(ps -C claude -o pid=,tty=,etime= 2>/dev/null | sort -k2)
    [[ $found -eq 0 ]] && echo "(no claude processes running)"
    echo
    echo "ORPHAN = raw ssh pty, dies on disconnect. Adopt one: fleet adopt-live <pid>"
    echo "Or just let it finish its task, then restart it inside fleet: fleet new <name>"
    ;;

  adopt-live)
    ensure_server
    pid="${1:?usage: fleet adopt-live <pid> [name]  (get pid from: fleet detect)}"
    if ! kill -0 "$pid" 2>/dev/null; then echo "no process $pid"; exit 1; fi
    tty="$(ps -o tty= -p "$pid" 2>/dev/null | tr -d ' ')"
    # already in fleet?
    if T list-panes -s -t _fleet -F "#{pane_tty}" 2>/dev/null | grep -qx "/dev/$tty"; then
      echo "$pid is already in the fleet (tty $tty)"; exit 0
    fi
    base="$(basename "$(readlink "/proc/$pid/cwd" 2>/dev/null || echo proc)")"
    name="${2:-${base}-${pid}}"
    cat <<WARN
⚠  reptyr-ing a LIVE process. claude is multithreaded node — this usually works
   but can occasionally crash the session. don't do this to one you can't lose.
   moving pid $pid (tty $tty, cwd $(readlink /proc/$pid/cwd 2>/dev/null)) → fleet window '$name'
WARN
    # run reptyr INSIDE a new fleet pane; -T steals the whole terminal (claude + children).
    # keep the pane alive on failure so the error is visible.
    T new-window -t _fleet -n "$name" \
      "echo 'adopting $pid via reptyr…'; sudo reptyr -T $pid; echo; echo '[reptyr exited — if claude is not above, adoption failed; original session is unaffected]'; exec bash"
    echo "→ launched adoption in window '$name'. watch it: fleet attach $name"
    echo "  if it worked, claude is now durable. if the pane shows an error, your original session is untouched."
    ;;

  manager)
    ensure_server
    brief="$HOME/.config/fleet/MANAGER.md"
    if T list-windows -t _fleet -F "#{window_name}" 2>/dev/null | grep -qx "manager"; then
      echo "manager already running — fleet attach manager"; exit 0
    fi
    # the AI manager is a normal interactive (subscription-billed) claude session,
    # pre-loaded with the operating brief so it knows it's the fleet controller.
    T new-window -t _fleet -n manager \
      "claude --dangerously-skip-permissions --append-system-prompt \"\$(cat '$brief')\""
    echo "manager launched. attach: fleet attach manager"
    echo "then tell it: 'run fleet status and give me the roll-up'"
    ;;

  kill)
    name="${1:?usage: fleet kill <name>}"
    T kill-window -t "_fleet:$name" 2>/dev/null && echo "killed '$name'" || { echo "no session '$name'"; exit 1; }
    ;;

  *)
    grep -E '^#   fleet' "$0" | sed 's/^#   /  /'
    ;;
esac
